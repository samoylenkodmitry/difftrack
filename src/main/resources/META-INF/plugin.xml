<idea-plugin url="https://github.com/samoylenkodmitry/difftrack#readme">
    <id>dev.branchlens</id>
    <name>Branch Lens</name>
    <vendor email="trdmitriisamoilenko@gmail.com" url="https://github.com/samoylenkodmitry/difftrack">Branch Lens</vendor>

    <description><![CDATA[
        Shows gutter badges next to lines that differ in other local Git branches.
        Click a badge to see which branches diverged, the branch-side text, and
        blame information for the corresponding line.<br/>
        <br/>
        Local Git only. No remotes, no network, no fuzzy matching.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="branchlens-git.xml">Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="dev.branchlens.BranchLensProjectService"/>
        <projectService serviceImplementation="dev.branchlens.cache.BranchLensCache"/>
        <projectService serviceImplementation="dev.branchlens.settings.BranchLensProjectSettings"/>
        <applicationService serviceImplementation="dev.branchlens.settings.BranchLensSettings"/>
        <projectConfigurable
            parentId="tools"
            instance="dev.branchlens.settings.BranchLensConfigurable"
            id="dev.branchlens.settings"
            displayName="Branch Lens"/>
        <postStartupActivity implementation="dev.branchlens.BranchLensStartupActivity"/>
        <toolWindow id="Branch Lens"
                    anchor="bottom"
                    icon="AllIcons.Vcs.Branch"
                    factoryClass="dev.branchlens.ui.BranchLensToolWindowFactory"/>
        <diffExtension implementation="dev.branchlens.diff.BranchLensDiffExtension"/>
    </extensions>

    <actions>
        <action id="dev.branchlens.CompareFileWithBranch"
                class="dev.branchlens.actions.CompareFileWithBranchAction"
                text="Compare File with Git Branch…"
                description="Show the current file next to its version on another locally available Git branch">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="Vcs.MainMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
